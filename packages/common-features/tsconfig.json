{
	"compilerOptions": {
		"baseUrl": ".",
		"target": "ES2017",
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"paths": {
			"@/*": ["../../apps/main/src/*", "../../apps/seller/src/*"]
		},
		"jsx": "preserve",
		"incremental": true
	},
	"include": ["src/**/*"]
}
